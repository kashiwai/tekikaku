{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git merge*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(curl *)",
      "Bash(which *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "WebFetch",
      "WebSearch",
      "mcp__cipher__ask_cipher",
      "mcp__claudepoint__*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git reset --hard)",
      "Bash(sudo *)"
    ]
  },
  "hooks": {
    "PreToolExecution": {
      "Bash(git push*)": {
        "command": "echo '⚠️ DEPLOY: git push requires approval'",
        "requiresApproval": true
      },
      "Bash(railway *)": {
        "command": "echo '⚠️ DEPLOY: Railway command requires approval'",
        "requiresApproval": true
      },
      "Bash(npm run deploy*)": {
        "command": "echo '⚠️ DEPLOY: Deploy command requires approval'",
        "requiresApproval": true
      },
      "Bash(vercel *)": {
        "command": "echo '⚠️ DEPLOY: Vercel command requires approval'",
        "requiresApproval": true
      }
    },
    "PostToolExecution": {
      "Bash(npm run build)": {
        "command": "echo '✅ Build completed'",
        "enabled": true
      }
    }
  },
  "context": {
    "includeFiles": [
      "CLAUDE.md",
      ".env.example",
      "package.json"
    ],
    "excludePatterns": [
      "node_modules/**",
      ".next/**",
      "*.lock"
    ]
  }
}
