# Railway Environment Variables Template
# Copy these variables to Railway Dashboard → Settings → Environment

# === MySQL Database (Provided by Railway) ===
DATABASE_HOST=${{MySQL.MYSQL_HOST}}
DATABASE_PORT=${{MySQL.MYSQL_PORT}}
DATABASE_USER=${{MySQL.MYSQL_USER}}
DATABASE_PASSWORD=${{MySQL.MYSQL_PASSWORD}}
DATABASE_NAME=${{MySQL.MYSQL_DATABASE}}

# === Signaling Server Configuration ===
SIGNALING_HOST=${{net8-signaling.RAILWAY_PUBLIC_DOMAIN}}
SIGNALING_PORT=443

# === PeerJS Server Settings ===
PEERJS_KEY=peerjs
PEERJS_PATH=/peerjs

# === Server Configuration ===
# Railway will automatically set PORT environment variable
# PORT=${PORT}
