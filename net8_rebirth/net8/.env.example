# NET8 Docker Environment Configuration
# このファイルを.envにコピーして、実際の値を設定してください
# cp .env.example .env

# ==========================================
# Database Settings
# ==========================================
DB_HOST=db
DB_NAME=net8_dev
DB_USER=net8user
DB_PASSWORD=net8pass
MYSQL_ROOT_PASSWORD=root_password_change_me

# ==========================================
# Site Settings
# ==========================================
SITE_NAME=NET8 System
SITE_URL=http://localhost:8080
ADMIN_EMAIL=admin@example.com

# ==========================================
# Signaling Server Settings (PeerJS)
# ==========================================
SIGNALING_HOST=localhost
SIGNALING_PORT=59000
SIGNALING_KEY=peerjs
SIGNALING_PATH=/

# ==========================================
# STUN/TURN Server Settings
# ==========================================
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=
TURN_USERNAME=
TURN_CREDENTIAL=

# ==========================================
# Application Settings
# ==========================================
DEBUG_MODE=true
LOG_LEVEL=INFO
CACHE_ENABLED=false

# ==========================================
# License Settings
# ==========================================
LICENSE_CODE=
LICENSE_TYPE=trial
LICENSE_EXPIRY=
LICENSE_MAX_USERS=10
LICENSE_MAX_CAMERAS=10
LICENSE_CHECK_ENABLED=false
LICENSE_SERVER_URL=

# ==========================================
# Feature Flags
# ==========================================
FEATURE_API_ACCESS=false
FEATURE_ADVANCED_ANALYTICS=false
FEATURE_CLOUD_STORAGE=false
FEATURE_MULTI_SITE=false

# ==========================================
# Mail Settings (Optional)
# ==========================================
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=NET8 System
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=

# ==========================================
# AWS Settings (for migration)
# ==========================================
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# ECR_REPOSITORY_URI=
# ECS_CLUSTER_NAME=
# RDS_ENDPOINT=
