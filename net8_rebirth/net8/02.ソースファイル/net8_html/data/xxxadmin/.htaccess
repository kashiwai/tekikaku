# Basic認証設定（Docker環境用に調整）
# NOTE: PHP session-based authentication is used instead of Basic Auth
# Basic Auth is disabled to prevent 401 errors and allow direct PHP access
# AuthUserFile /var/www/html/.htpasswd-admin
# AuthName "NET8 Admin Area"
# AuthType Basic
# Require valid-user

# Docker環境では全IPからのアクセスを許可
# 本番環境では以下のRequire ip行のコメントを外して制限してください
# Require ip xxx.xxx.xxx.xxx
