@echo off
REM ============================================
REM シンプルMAC収集スクリプト
REM ネットワーク内の全デバイスをスキャン
REM ============================================

echo ============================================
echo MACアドレス収集ツール
echo ============================================
echo.

set /p NETWORK="ネットワーク範囲を入力 (例: 192.168.1): "

echo.
echo %NETWORK%.1 - %NETWORK%.254 をスキャン中...
echo しばらくお待ちください...
echo.

REM 全IPにPingを送信（ARPテーブルを更新）
for /L %%i in (1,1,254) do (
    ping -n 1 -w 100 %NETWORK%.%%i >nul 2>&1
)

echo.
echo スキャン完了。ARPテーブルを表示:
echo.
echo ============================================
arp -a | findstr %NETWORK%
echo ============================================
echo.
echo 上記の結果をコピーしてください。
pause
